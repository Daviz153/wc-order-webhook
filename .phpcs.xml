<?xml version="1.0"?>
<ruleset name="WC Order Webhook">
    <description>WC Order Webhook 플러그인 코딩 스탠다드</description>

    <file>.</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*.js</exclude-pattern>
    <exclude-pattern>*.css</exclude-pattern>

    <!-- WordPress 핵심 규칙 (보안·로직) 적용 -->
    <rule ref="WordPress-Core">
        <!-- PHP 숏태그 (<?=) 허용 — 템플릿 출력에 사용 -->
        <exclude name="Generic.PHP.DisallowShortOpenTag.EchoFound"/>
        <!-- 들여쓰기: tab 사용 (프로젝트 스타일) -->
        <exclude name="Generic.WhiteSpace.DisallowTabIndent"/>
        <!-- 인라인 주석 문장 부호 불요 -->
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Squiz.Commenting.InlineComment.SpacingBefore"/>
        <!-- 빈 파일 docblock 불요 -->
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        <exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
        <!-- 클래스 docblock 불요 -->
        <exclude name="Squiz.Commenting.ClassComment.Missing"/>
        <!-- 메서드 docblock 불요 -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.MissingReturn"/>
        <exclude name="Squiz.Commenting.FunctionComment.ReturnCommentFullStop"/>
        <!-- 변수 주석 불요 -->
        <exclude name="Squiz.Commenting.VariableComment.Missing"/>
        <!-- 여는 중괄호 위치 (PSR 스타일 허용) -->
        <exclude name="Generic.Classes.OpeningBraceSameLine"/>
        <exclude name="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine"/>
        <!-- 요다 조건식 선택적 -->
        <exclude name="WordPress.PHP.YodaConditions"/>
        <!-- 배열 출력 스타일 -->
        <exclude name="WordPress.Arrays.ArrayDeclarationSpacing"/>
        <!-- 문자열 번역 불요 (UI 텍스트는 한국어 하드코딩) -->
        <exclude name="WordPress.WP.I18n"/>
        <!-- 줄 길이 제한 완화 -->
        <exclude name="Generic.Files.LineLength"/>
        <!-- 파일명 규칙 (class-admin.php 등 유지) -->
        <exclude name="WordPress.Files.FileName"/>
        <!-- 단축 삼항 (?:) 허용 -->
        <exclude name="Universal.Operators.DisallowShortTernary"/>
    </rule>

    <!-- 보안 규칙은 반드시 적용 -->
    <rule ref="WordPress.Security"/>

    <!-- PHP 8.2 호환 -->
    <config name="testVersion" value="8.2-"/>
</ruleset>
